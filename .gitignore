# monorepo root .gitignore
# template/ 配下の .gitignore と独立、root の workspace 全体に効く

# dependencies (workspace root の node_modules と各 package の node_modules 両方)
node_modules
**/node_modules

# build outputs
.next
**/.next
dist
**/dist
*.tsbuildinfo
**/*.tsbuildinfo

# env
.env
.env.local
.env.*.local
**/.env
**/.env.local
**/.env.*.local

# vercel / turbo
.vercel
**/.vercel
.turbo
**/.turbo

# test artifacts
coverage
**/coverage
test-results
**/test-results
*-results

# OS / IDE
.DS_Store
**/.DS_Store
*.swp
.vscode
.idea

# logs
*.log
**/*.log
npm-debug.log*
pnpm-debug.log*

# next.js
next-env.d.ts

# CHANGELOG generated by changesets (任意で commit するなら削除)
# CHANGELOG.md
