{
  "name": "@takuma-hirai/create-app",
  "version": "0.1.1",
  "description": "ClassLab Next.js Clean Architecture template scaffolder",
  "type": "module",
  "bin": {
    "create-classlab-app": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "bash ../../.claude/tests/create-app-fresh-install-e2e.sh"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "execa": "^9.5.1",
    "giget": "^3.2.0",
    "kleur": "^4.1.5",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@types/node": "^20.14.0",
    "@types/prompts": "^2.4.9",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
