{
  "name": "next-clean-arch-template",
  "version": "0.1.0",
  "private": true,
  "description": "Recall.ai POC Web フロント (Next.js 14 App Router + Zustand)。Linear/Vercel variant design を pixel-perfect で port。",
  "scripts": {
    "env:validate": "tsx scripts/env-validate.ts",
    "dev": "next dev -p 3000",
    "build": "next build",
    "prebuild": "pnpm env:validate",
    "start": "next start -p 3000",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:next": "next lint",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint:circular": "madge --circular --extensions ts src/lib",
    "deps:check": "madge --circular --extensions ts src/lib/",
    "deps:layers": "madge --no-color --extensions ts src/lib/",
    "bundle:check": "node scripts/bundle-size.mjs",
    "test:template-iso": "bash e2e/template-iso/fresh-install.test.sh"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.35.0",
    "@emotion/react": "^11.14.0",
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.16.0",
    "next": "^14.2.0",
    "next-themes": "^0.4.6",
    "pino": "^10.3.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hook-form": "^7.76.1",
    "reflect-metadata": "^0.2.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tsyringe": "^4.10.0",
    "zod": "^3.23.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/eslintrc": "^3.3.5",
    "@next/env": "^16.2.7",
    "@vercel/config": "^0.5.0",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^2.1.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.4.0",
    "eslint-config-next": "^16.2.6",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "madge": "^8.0.0",
    "postcss": "^8.5.15",
    "tsx": "^4.22.3",
    "typescript": "^5.4.0",
    "vitest": "^2.1.0",
    "vitest-axe": "^0.1.0"
  }
}
