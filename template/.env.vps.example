# .env.vps.example
# Example environment variables for vps-next-postgres profile.
# Copy this file to .env and fill in real values before deploying.
#
# Usage:
#   cp .env.vps.example .env
#   # Edit .env with actual secrets
#   ./scripts/setup-vps-postgres.sh

# ── Deploy profile ─────────────────────────────────────────────────
# Fixed for this profile. Do not change.
# MOCK_MODE must stay false: MOCK_MODE=true wires the mock auth adapter
# (auth bypass). The server refuses to boot with MOCK_MODE=true in
# NODE_ENV=production (src/instrumentation.ts fail-fast guard) — the
# MOCK_MODE=true exception for this profile exists for build-time
# verification only (e.g. inside the Dockerfile build stage).
DEPLOY_PROFILE=vps-next-postgres
MOCK_MODE=false

# ── PostgreSQL ─────────────────────────────────────────────────────
# Connection string for the Prisma client (used by the Next.js app server).
# Format: postgresql://<user>:<password>@<host>:<port>/<db>
# For docker-compose.vps.yml: the host is the service name 'postgres'.
# For external Postgres (e.g. Railway, Supabase Postgres): use the full URL.
DATABASE_URL=postgresql://appuser:CHANGE_ME_PASSWORD@localhost:5432/appdb

# Docker Compose postgres service credentials (used by docker-compose.vps.yml).
POSTGRES_USER=appuser
POSTGRES_PASSWORD=CHANGE_ME_PASSWORD
POSTGRES_DB=appdb

# ── NextAuth v5 ────────────────────────────────────────────────────
# Secret used to sign JWT session tokens. Must be at least 32 characters.
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_32

# Public URL of your app (used by NextAuth for OAuth redirect and CSRF).
# Must be the actual domain (e.g. https://app.example.com).
# The scheme also drives session cookie naming: https:// → __Secure- prefixed
# cookie (middleware reads the same signal — keep this accurate for staging).
NEXTAUTH_URL=https://app.example.com

# Session note: JWT sessions expire after 1 hour (maxAge in src/auth.ts).
# Role changes (e.g. admin → member) take effect on re-login, on client
# session.update(), or at the latest when the 1-hour token expires.

# ── Google OAuth (required when LOGIN_STRATEGY=sso or both) ───────
# Create credentials at: https://console.developers.google.com/
# Authorized redirect URIs must include: ${NEXTAUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret

# ── Auth domain restriction (optional) ────────────────────────────
# When set, only emails ending with @<domain> are accepted at sign-in.
# Both Google OAuth and credentials logins are restricted.
# Leave empty (or remove) to allow all email domains.
# Matching is case-INsensitive (RFC 5321) and a leading '@' is tolerated:
# 'example.com', 'EXAMPLE.COM' and '@example.com' all behave the same.
# Subdomains are NOT matched (sub.example.com is rejected for example.com).
# Example: AUTH_ALLOWED_EMAIL_DOMAIN=example.com
AUTH_ALLOWED_EMAIL_DOMAIN=

# ── Login strategy ─────────────────────────────────────────────────
# Controls which login methods are shown on the sign-in page.
#   sso        — Google OAuth button only
#   email-pass — Email + password form only
#   both       — Both methods (tabs UI)
LOGIN_STRATEGY=both

# ── Rate limiting ──────────────────────────────────────────────────
# Must be true when LOGIN_STRATEGY is email-pass or both (brute-force protection).
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_ATTEMPTS=5
RATE_LIMIT_WINDOW_SEC=900

# ── Recall.ai ──────────────────────────────────────────────────────
# Required when MOCK_MODE=false (env-schema refinement 1): this profile wires
# the real Recall.ai adapters (BotOrchestrator / Transcription / WebhookVerifier).
# Obtain from: https://app.recall.ai > Settings > API Keys
RECALL_API_KEY=

# ── Seed script ────────────────────────────────────────────────────
# Password used for all users created by scripts/seed-users.ts.
#
# CHANGE THIS BEFORE THE FIRST SEED RUN. The seed script refuses to run with
# the default password when NODE_ENV=production or DATABASE_URL points at a
# non-local host (production guard).
#
# NOTE: re-running the seed does NOT update passwords of existing users
# (upsert with empty update). To rotate a seed user's password, delete the
# row and re-run, or update passwordHash manually.
# Default if unset: changeme-local-only (local development only)
SEED_PASSWORD=changeme-local-only
