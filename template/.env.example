# ==============================================================
# Supabase
# Required: Supabase project URL and keys.
# Obtain from: https://app.supabase.com/project/<ref>/settings/api
# ==============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here-at-least-32-chars
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here-at-least-32-chars

# SUPABASE_DB_URL — PostgreSQL direct connection URL for psql / pg_cron (D-M-04).
# Required when using scripts/setup-supabase.sh Phase 6 (remote mode).
# Obtain from: https://app.supabase.com/project/<ref>/settings/database
# Example: postgresql://postgres:password@db.<ref>.supabase.co:5432/postgres
# SUPABASE_DB_URL=

# ==============================================================
# Google OAuth (Supabase Auth provider)
# Required: Google OAuth credentials for SSO login.
# Obtain from: https://console.cloud.google.com > APIs & Services > Credentials
# ==============================================================
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret-here

# ==============================================================
# Admin (initial seed user for allowed_users table)
# Required: Must be a valid email address.
# ALLOWED_ADMIN_EMAIL_DOMAIN (optional, D-H-01):
#   If set, INITIAL_ADMIN_EMAIL must end with this domain suffix.
#   Leave empty to allow any domain (useful for template adoption by other orgs).
#   Example: ALLOWED_ADMIN_EMAIL_DOMAIN=@classlab.co.jp
# ==============================================================
INITIAL_ADMIN_EMAIL=admin@classlab.co.jp
# ALLOWED_ADMIN_EMAIL_DOMAIN=@classlab.co.jp

# ==============================================================
# Deployment profile (minimal | unlocked | pro | vps | vps-next-postgres | vps-next-mariadb)
# Controls which adapters are wired (see src/lib/infrastructure/profiles/mapping.ts).
# Default: minimal
# vps-next-postgres  = self-hosted VPS with NextAuth v5 + Prisma + PostgreSQL
#   (no Supabase). See the dedicated section below and .env.vps.example.
# vps-next-mariadb   = self-hosted VPS with MariaDB 11 + NextAuth v5 (identical
#   auth stack to vps-next-postgres, mysql provider). See .env.mariadb.example.
#   DATABASE_URL must use the mysql:// scheme (e.g. mysql://user:pass@host:3307/db).
# ==============================================================
DEPLOY_PROFILE=minimal

# ==============================================================
# Mock mode (true = MockGateway, false = real Recall.ai API)
# Set to true for local development without Recall.ai API key.
# Default: true
# ==============================================================
MOCK_MODE=true

# ==============================================================
# Recall.ai (optional when MOCK_MODE=true, required when MOCK_MODE=false)
# Obtain from: https://app.recall.ai > Settings > API Keys
# WEBHOOK_PUBLIC_URL: public URL for receiving Recall.ai webhooks (e.g. ngrok URL)
# ==============================================================
RECALL_API_KEY=
WEBHOOK_PUBLIC_URL=

# ==============================================================
# Vercel (auto-set in Vercel production, manual for local dev)
# Optional: used by setup-vercel.sh for project identification.
# ==============================================================
VERCEL_PROJECT_ID=
VERCEL_ORG_ID=

# ==============================================================
# Build / CI utilities
# SKIP_ENV_VALIDATE=true skips pnpm env:validate in prebuild (A-H-03).
# Use only for CI debug or when env is known valid at CI level.
# Never set this in .env.local for regular development.
# ==============================================================
# SKIP_ENV_VALIDATE=false

# ── Rate Limit (task #36, OWASP A07 — auth brute-force 対策) ──────────
# 認証エンドポイント (sign-in Server Action) への in-memory fixed-window rate-limit。
# backend (in-memory / Upstash) の選択は DEPLOY_PROFILE の profile mapping で表現するため、
# RATE_LIMIT_BACKEND env は存在しない:
#   minimal / unlocked = InMemoryRateLimiterAdapter (single-instance POC)
#   pro / vps          = UpstashRateLimiterAdapter (本番 serverless / multi-instance)
#
# 重要: in-memory backend は single-instance 前提。本番 serverless (pro/vps profile) は
#       multi-instance で window が instance ローカルになり不正確なため、Upstash 等の
#       分散カウンタ backend が必須。
# 既知制約: fixed-window は窓境界で 2N-1 試行が短時間に通る (boundary burst)。
#           sliding-window は Upstash 差替後に対応。
#
# RATE_LIMIT_ENABLED: rate-limit 機構の有効化。default 'false'。
#   LOGIN_STRATEGY=sso 専用構成でも 'true' を推奨 (Google OAuth invalid_grant flooding 対策)。
#   email-pass を有効化する構成では必須化される (login task #37 Step 4 の superRefine guard)。
RATE_LIMIT_ENABLED=false
# RATE_LIMIT_MAX_ATTEMPTS: window あたりの fail 上限。default 5。
RATE_LIMIT_MAX_ATTEMPTS=5
# RATE_LIMIT_WINDOW_SEC: window 長 (秒)。default 900 (= 15min)。
RATE_LIMIT_WINDOW_SEC=900

# ─────────────────────────────────────────────────────────────────────
# Login strategy (task #37, auth-login-strategy)
# ─────────────────────────────────────────────────────────────────────
# LOGIN_STRATEGY — どのサインイン手段を出すか (private env, NEXT_PUBLIC_ なし)。
#   sso        : Google OAuth button のみ
#   email-pass : email + password form のみ
#   both       : Tabs で両方 (template consumer 推奨。recall_poc 自体は sso)
# 注意: email-pass / both にする場合は RATE_LIMIT_ENABLED=true が必須
#   (env-schema superRefine が起動時に強制。brute-force 対策, task #36)。
LOGIN_STRATEGY=sso

# MOCK_SEED_EMAIL / MOCK_SEED_PASSWORD — MOCK_MODE=true の email-pass sign-in 用
#   seed credential。未指定時は MockAuthAdapter default
#   (test@classlab.co.jp / password123) が使われる。**本番では設定しない**。
#   getValidatedEnv() 経由で server から読む (process.env 直接アクセス禁止)。
MOCK_SEED_EMAIL=test@classlab.co.jp
MOCK_SEED_PASSWORD=password123

# ─────────────────────────────────────────────────────────────────────
# vps-next-postgres profile (NextAuth v5 + Prisma + PostgreSQL, no Supabase)
# ─────────────────────────────────────────────────────────────────────
# These keys are required only when DEPLOY_PROFILE=vps-next-postgres and
# MOCK_MODE=false (env-schema refinement 7). The local default (MOCK_MODE=true)
# does NOT need any of them — leave commented out for local development.
# For a full VPS deployment walkthrough see .env.vps.example +
# scripts/setup-vps-postgres.sh + docker-compose.vps.yml.

# DATABASE_URL — Prisma connection string to PostgreSQL.
#   Format: postgresql://<user>:<password>@<host>:<port>/<db>
# DATABASE_URL=postgresql://appuser:CHANGE_ME@localhost:5432/appdb

# NEXTAUTH_SECRET — JWT session signing/encryption secret (min 32 chars).
#   Generate with: openssl rand -base64 32
# NEXTAUTH_SECRET=

# NEXTAUTH_URL — public URL of the app (OAuth redirect + CSRF + cookie security).
#   https:// scheme → __Secure- prefixed session cookie.
# NEXTAUTH_URL=https://app.example.com

# AUTH_GOOGLE_ID / AUTH_GOOGLE_SECRET — Google OAuth credentials for NextAuth.
#   NOTE: NextAuth naming — distinct from the Supabase-profile
#   GOOGLE_OAUTH_CLIENT_ID / GOOGLE_OAUTH_CLIENT_SECRET above.
#   Required when LOGIN_STRATEGY=sso or both on this profile.
# AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
# AUTH_GOOGLE_SECRET=your-google-client-secret

# AUTH_ALLOWED_EMAIL_DOMAIN — optional sign-in domain restriction.
#   Only emails ending with @<domain> may sign in (Google OAuth + credentials).
#   Case-insensitive; leading '@' tolerated; subdomains NOT matched.
#   Leave empty/unset to allow all domains.
# AUTH_ALLOWED_EMAIL_DOMAIN=example.com

# SEED_PASSWORD — password for scripts/seed-users.ts seed users.
#   Must be changed from the default before seeding a production DB
#   (the seed script refuses the default in production environments).
# SEED_PASSWORD=changeme-local-only

# ─────────────────────────────────────────────────────────────────────
# vps-next-mariadb profile (NextAuth v5 + Prisma + MariaDB 11, no Supabase)
# ─────────────────────────────────────────────────────────────────────
# Identical auth stack to vps-next-postgres. Only the database provider differs:
# Prisma mysql provider + MariaDB 11 instead of PostgreSQL 16.
#
# These keys are required only when DEPLOY_PROFILE=vps-next-mariadb and
# MOCK_MODE=false (env-schema refinement 8). MOCK_MODE=true does NOT need any
# of them — leave commented out for local development.
# For a full VPS deployment walkthrough see .env.mariadb.example and
# docker-compose.mariadb.yml.
#
# DATABASE_URL — Prisma connection string to MariaDB. MUST use mysql:// scheme.
#   Format: mysql://<user>:<password>@<host>:<port>/<db>
#   Port note: host-side access uses 3307 (3306 occupied per recon).
#             In-compose app service uses port 3306 (container network).
# DATABASE_URL=mysql://appuser:CHANGE_ME@localhost:3307/appdb

# NEXTAUTH_SECRET / NEXTAUTH_URL — same semantics as vps-next-postgres.
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=https://app.example.com

# AUTH_GOOGLE_ID / AUTH_GOOGLE_SECRET — NextAuth Google provider credentials.
#   Required when LOGIN_STRATEGY=sso or both on this profile.
# AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
# AUTH_GOOGLE_SECRET=your-google-client-secret

# ─────────────────────────────────────────────────────────────────────
# vps-nest-postgres profile (NestJS auth + Prisma + PostgreSQL, no Supabase, no NextAuth)
# ─────────────────────────────────────────────────────────────────────
# Auth is owned by the Nest API (api/ directory). Next.js reads the HS256 JWT
# cookie set by Nest in Edge middleware (jose jwtVerify).
#
# These keys are required only when DEPLOY_PROFILE=vps-nest-postgres and
# MOCK_MODE=false (env-schema refinement 9). MOCK_MODE=true does NOT need any
# of them — leave commented out for local development.
# For deployment see docker-compose.nest-postgres.yml.

# JWT_SECRET — HS256 signing secret shared by Nest (token signing) and Next.js
#   Edge middleware (jwtVerify). Minimum 32 characters.
#   Generate with: openssl rand -base64 32
#   MUST be identical in both api/.env and this file.
# JWT_SECRET=

# NEST_API_URL — private server-side URL of the Nest API (no NEXT_PUBLIC_ prefix).
#   Used by Next.js Server Actions and the sign-out route handler to call Nest.
#   Example for Docker Compose: http://api:3001
#   Example for local dev:      http://localhost:3001
# NEST_API_URL=http://localhost:3001

# DATABASE_URL — Prisma connection string to PostgreSQL.
#   Format: postgresql://<user>:<password>@<host>:<port>/<db>
# DATABASE_URL=postgresql://appuser:CHANGE_ME@localhost:5432/appdb

# AUTH_GOOGLE_ID / AUTH_GOOGLE_SECRET — Google OAuth credentials used by Nest passport-google.
#   Required when LOGIN_STRATEGY=sso or both on this profile.
#   NOTE: same AUTH_GOOGLE_* naming convention as vps-next-postgres (not GOOGLE_OAUTH_CLIENT_*).
#   Must also be set in api/.env (NestJS ConfigService reads them there).
# AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
# AUTH_GOOGLE_SECRET=your-google-client-secret

# AUTH_ALLOWED_EMAIL_DOMAIN — optional sign-in domain restriction (Next.js side mirror).
#   The Nest auth.service.ts enforces this for credentials login.
# AUTH_ALLOWED_EMAIL_DOMAIN=example.com

# RECALL_API_KEY — required when MOCK_MODE=false (env-schema refinement 1).
#   docker-compose.nest-postgres.yml passes this through to the web container;
#   without it the web container fails env validation at startup.
# RECALL_API_KEY=

# ─────────────────────────────────────────────────────────────────────
# vps-nest-mariadb profile (NestJS auth + Prisma + MariaDB 11, no Supabase, no NextAuth)
# ─────────────────────────────────────────────────────────────────────
# Identical auth stack to vps-nest-postgres. Only the database provider differs:
# Prisma mysql provider + MariaDB 11 instead of PostgreSQL 16.
#
# These keys are required only when DEPLOY_PROFILE=vps-nest-mariadb and
# MOCK_MODE=false (env-schema refinement 10). MOCK_MODE=true does NOT need any
# of them — leave commented out for local development.
# For deployment see docker-compose.nest-mariadb.yml.

# JWT_SECRET / NEST_API_URL — same semantics as vps-nest-postgres.
# JWT_SECRET=
# NEST_API_URL=http://localhost:3001

# DATABASE_URL — Prisma connection string to MariaDB. MUST use mysql:// scheme.
#   Format: mysql://<user>:<password>@<host>:<port>/<db>
# DATABASE_URL=mysql://appuser:CHANGE_ME@localhost:3307/appdb

# AUTH_GOOGLE_ID / AUTH_GOOGLE_SECRET — same as vps-nest-postgres.
# AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
# AUTH_GOOGLE_SECRET=your-google-client-secret

# RECALL_API_KEY — required when MOCK_MODE=false (env-schema refinement 1).
#   docker-compose.nest-mariadb.yml passes this through to the web container;
#   without it the web container fails env validation at startup.
# RECALL_API_KEY=
