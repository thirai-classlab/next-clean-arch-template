# ── Nest API environment variables ──────────────────────────────────────────
# Copy to .env and fill in real values for local development.

# JWT secret — MUST be at least 32 characters. Used to sign 'nest-session-token' cookies.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars

# PostgreSQL connection string (vps-nest-postgres profile)
# DATABASE_URL=postgresql://user:pass@localhost:5432/dbname

# MariaDB connection string (vps-nest-mariadb profile)
# DATABASE_URL=mysql://user:pass@localhost:3306/dbname

# Nest API public URL (used as Google OAuth callbackURL base)
NEST_API_URL=http://localhost:3001

# Next.js app URL (for CORS and post-OAuth redirect)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth credentials (required when LOGIN_STRATEGY includes SSO)
# AUTH_GOOGLE_ID=your-client-id.apps.googleusercontent.com
# AUTH_GOOGLE_SECRET=your-client-secret

# Optional: restrict sign-in to a specific email domain (e.g. example.com or @example.com)
# AUTH_ALLOWED_EMAIL_DOMAIN=

# Sign-in strategy: sso (Google only) | email-pass | both
LOGIN_STRATEGY=both

# Deploy profile: vps-nest-postgres | vps-nest-mariadb
DEPLOY_PROFILE=vps-nest-postgres
