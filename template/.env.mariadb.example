# .env.mariadb.example
# Example environment variables for vps-next-mariadb profile.
# Copy this file to .env and fill in real values before deploying.
#
# Usage:
#   cp .env.mariadb.example .env
#   # Edit .env with actual secrets
#   docker compose -f docker-compose.mariadb.yml up -d
#   pnpm prisma migrate deploy --schema prisma/mariadb/schema.prisma
#   pnpm db:seed:mariadb
#
# Port note: DATABASE_URL below uses port 3307 for host-side access
# (migrate / seed commands run on the host). The Docker compose service uses
# port 3306 internally (mysql://...@mariadb:3306/...). Keep both consistent.

# ── Deploy profile ─────────────────────────────────────────────────
# Fixed for this profile. Do not change.
# MOCK_MODE must stay false: MOCK_MODE=true wires the mock auth adapter
# (auth bypass). The server refuses to boot with MOCK_MODE=true in
# NODE_ENV=production (src/instrumentation.ts fail-fast guard).
DEPLOY_PROFILE=vps-next-mariadb
MOCK_MODE=false

# ── MariaDB ────────────────────────────────────────────────────────
# Connection string for the Prisma client (used by the Next.js app server).
# Format: mysql://<user>:<password>@<host>:<port>/<db>
# For docker-compose.mariadb.yml host-side access: use localhost:3307
#   (MariaDB is bound to 127.0.0.1:3307 on the host — see port note above).
# For the app container (in-compose): host is the service name 'mariadb', port 3306.
DATABASE_URL=mysql://appuser:CHANGE_ME_PASSWORD@localhost:3307/appdb

# Docker Compose mariadb service credentials (used by docker-compose.mariadb.yml).
MARIADB_USER=appuser
MARIADB_PASSWORD=CHANGE_ME_PASSWORD
MARIADB_DATABASE=appdb
MARIADB_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD

# ── NextAuth v5 ────────────────────────────────────────────────────
# Secret used to sign JWT session tokens. Must be at least 32 characters.
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_32

# Public URL of your app (used by NextAuth for OAuth redirect and CSRF).
# Must be the actual domain (e.g. https://app.example.com).
NEXTAUTH_URL=https://app.example.com

# ── Google OAuth (required when LOGIN_STRATEGY=sso or both) ───────
# Create credentials at: https://console.developers.google.com/
# Authorized redirect URIs must include: ${NEXTAUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret

# ── Auth domain restriction (optional) ────────────────────────────
# When set, only emails ending with @<domain> are accepted at sign-in.
# Leave empty (or remove) to allow all email domains.
AUTH_ALLOWED_EMAIL_DOMAIN=

# ── Login strategy ─────────────────────────────────────────────────
# Controls which login methods are shown on the sign-in page.
#   sso        — Google OAuth button only
#   email-pass — Email + password form only
#   both       — Both methods (tabs UI)
LOGIN_STRATEGY=both

# ── Rate limiting ──────────────────────────────────────────────────
# Must be true when LOGIN_STRATEGY is email-pass or both (brute-force protection).
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_ATTEMPTS=5
RATE_LIMIT_WINDOW_SEC=900

# ── Recall.ai ──────────────────────────────────────────────────────
# Required when MOCK_MODE=false (env-schema refinement 1).
RECALL_API_KEY=

# ── Seed script ────────────────────────────────────────────────────
# Password used for all users created by scripts/seed-users.ts.
# CHANGE THIS BEFORE THE FIRST SEED RUN.
SEED_PASSWORD=changeme-local-only
